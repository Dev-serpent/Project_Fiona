#!/bin/bash

SOURCE_DIR="$(pwd)"
BACKUP_DIR="$SOURCE_DIR/.backups"

MARK="backup"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mark)
            MARK="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            echo "Usage: $0 [--mark <name>]"
            exit 1
            ;;
    esac
done

mkdir -p "$BACKUP_DIR"

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_FILE="$BACKUP_DIR/backup-${TIMESTAMP}--${MARK}.tar.gz"

tar \
    --exclude='.git' \
    --exclude='node_modules' \
    --exclude='.backups' \
    --exclude='.codex' \
    --exclude='.agents' \
    --exclude='fiona.egg-info' \
    --exclude='__pycache__' \
    --exclude='*.pyc' \
    -czf "$BACKUP_FILE" .

echo "Backup created:"
echo "$BACKUP_FILE"
